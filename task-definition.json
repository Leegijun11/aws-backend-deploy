{
    "containerDefinitions": [
        {
            "name": "study-back-con",
            "image": "036230293765.dkr.ecr.ap-northeast-2.amazonaws.com/my-backend:latest",
            "cpu": 0,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "hostPort": 8000,
                    "protocol": "tcp",
                    "name": "study-back-con-8000-tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [
                { "name": "DB_USER", "value": "my_db_user" },
                { "name": "DB_PASSWORD", "value": "my_db_password" },
                { "name": "DB_HOST", "value": "my_rds_endpoint" },
                { "name": "DB_PORT", "value": "3306" },
                { "name": "DB_NAME", "value": "studydb" },
                { "name": "SECRET_KEY", "value": "my_secret_key" },
                { "name": "JWT_ALGORITHM", "value": "HS256" }
            ],
            "environmentFiles": [],
            "mountPoints": [],
            "volumesFrom": [],
            "ulimits": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/study-back-td",
                    "awslogs-region": "ap-northeast-2",
                    "awslogs-stream-prefix": "ecs"
                },
                "secretOptions": []
            },
            "systemControls": []
        }
    ],
    "family": "study-back-td",
    "executionRoleArn": "arn:aws:iam::036230293765:role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "placementConstraints": [],
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "tags": []
}
